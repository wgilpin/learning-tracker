DB_USER=tracker
DB_PASSWORD=changeme
DB_NAME=tracker
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}
GOOGLE_API_KEY=your-google-ai-api-key-here
GEMINI_MODEL=gemini-3-flash-preview
LOG_LEVEL=INFO
SESSION_SECRET_KEY=generate-a-real-secret-here
OPENALEX_API_KEY=your-openalex-api-key-here
SERPAPI_KEY=your-serpapi-key
PAPERSTORE_API_TOKEN=your-paperstore-api-token-here

# Generation cost display (adjust if you change models)
# Text model: gemini-3-flash-preview — https://ai.google.dev/gemini-api/docs/pricing
COST_INPUT_PER_M=0.50
COST_OUTPUT_PER_M=3.00
# Image model: gemini-3.1-flash-image-preview — billed per output token ($60/M ≈ $0.045–$0.151/image)
COST_PER_IMAGE=0.10
